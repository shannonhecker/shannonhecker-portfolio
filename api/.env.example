ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ADMIN_TOKEN=your-secret-admin-token
PORT=3001

# Optional: email notifications for new logged visitor questions.
# Requires a Resend API key and a verified sender domain/address.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# NOTIFY_EMAIL_TO=you@example.com
# NOTIFY_EMAIL_FROM=Ask Shannon <notifications@example.com>
# DASHBOARD_URL=https://ask-shannon-api.onrender.com/api/conversations

# Optional: absolute path for conversation history. On Render, attach a disk and set e.g.
# CONVERSATIONS_LOG_PATH=/var/data/conversations.log so logs survive deploys/restarts.
# CONVERSATIONS_LOG_PATH=
