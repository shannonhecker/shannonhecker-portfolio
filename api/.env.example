ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ADMIN_TOKEN=your-secret-admin-token
PORT=3001
# Optional: absolute path for conversation history. On Render, attach a disk and set e.g.
# CONVERSATIONS_LOG_PATH=/var/data/conversations.log so logs survive deploys/restarts.
# CONVERSATIONS_LOG_PATH=
# Optional: max conversation rows in RAM (default 2000). The log file keeps full append-only history.
# MAX_CONVERSATIONS_STORED=2000
