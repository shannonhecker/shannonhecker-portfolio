{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "$description": "Color tokens — semantic roles with light/dark mode values",
    "bg":         { "light": "#FFFFFF",  "dark": "#121212" },
    "surface":    { "light": "#FFFFFF",  "dark": "#1D1B20" },
    "panel":      { "light": "#F5F5F5",  "dark": "#211F26" },
    "ink":        { "light": "#0A0A0A",  "dark": "rgba(255,255,255,0.87)" },
    "ink-pure":   { "light": "#000000",  "dark": "#FFFFFF" },
    "mid":        { "light": "#555555",  "dark": "rgba(255,255,255,0.60)" },
    "light":      { "light": "#999999",  "dark": "rgba(255,255,255,0.38)" },
    "ghost":      { "light": "#CCCCCC",  "dark": "rgba(255,255,255,0.12)" },
    "rule":       { "light": "#E8E8E8",  "dark": "rgba(255,255,255,0.12)" },
    "rule-dk":    { "light": "#C8C8C8",  "dark": "rgba(255,255,255,0.20)" },
    "border":     { "light": "#C0C0C0",  "dark": "rgba(255,255,255,0.16)" },
    "nav":        { "light": "#595959",  "dark": "rgba(255,255,255,0.60)" },
    "hover":      { "light": "#111111",  "dark": "rgba(255,255,255,0.87)" },
    "accent":     { "light": "#4A90D9",  "dark": "#7AB3E8" },
    "success":    { "light": "#2E7D32",  "dark": "#66BB6A" },
    "warning":    { "light": "#ED6C02",  "dark": "#FFA726" },
    "error":      { "light": "#D32F2F",  "dark": "#EF5350" },
    "info":       { "light": "#0288D1",  "dark": "#29B6F6" },
    "available":  { "light": "#22c55e",  "dark": "#22c55e" }
  },
  "aurora": {
    "$description": "Aurora illustration color palettes used by orbs and guilloché lines",
    "hero": {
      "lavender":    "rgba(196,181,253,0.92)",
      "cyan":        "rgba(103,232,249,0.88)",
      "periwinkle":  "rgba(129,140,248,0.80)",
      "teal":        "rgba(94,234,212,0.75)"
    },
    "footer": {
      "pink":   "rgba(255,145,185,0.90)",
      "amber":  "rgba(255,198,95,0.86)",
      "coral":  "rgba(255,175,135,0.60)"
    },
    "cta": {
      "purple": "#a855f7",
      "pink":   "#ec4899",
      "amber":  "#f59e0b",
      "cyan":   "#22d3ee"
    }
  },
  "typography": {
    "$description": "Type scale, weights, line heights, and letter spacing",
    "family": {
      "body":    "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "display": "'Noto Serif Display', Georgia, 'Times New Roman', serif",
      "mono":    "'JetBrains Mono', 'Fira Code', 'Consolas', monospace"
    },
    "scale": {
      "micro":  { "min": 9,  "max": 10 },
      "tiny":   { "min": 11, "max": 12 },
      "sm":     { "min": 13, "max": 14 },
      "base":   { "min": 15, "max": 17 },
      "md":     { "min": 17, "max": 20 },
      "lg":     { "min": 22, "max": 28 },
      "xl":     { "min": 30, "max": 44 },
      "2xl":    { "min": 42, "max": 60 }
    },
    "specialtyScale": {
      "hero":            { "min": 72,  "max": 160 },
      "heroTagline":     { "min": 24,  "max": 36 },
      "workHero":        { "min": 40,  "max": 80 },
      "pageTitle":       { "min": 32,  "max": 56 },
      "section":         { "min": 22,  "max": 34 },
      "sectionBlock":    { "min": 24,  "max": 36 },
      "sectionTitle":    { "min": 16,  "max": 18 },
      "nextProject":     { "min": 24,  "max": 40 },
      "nextLabel":       { "min": 20,  "max": 28 },
      "aboutIntro":      { "min": 26,  "max": 40 },
      "contactHeading":  { "min": 40,  "max": 76 }
    },
    "weight": {
      "body":     300,
      "ui":       400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "lineHeight": {
      "tight":  1.1,
      "snug":   1.3,
      "normal": 1.5,
      "body":   1.75,
      "prose":  1.85
    },
    "letterSpacing": {
      "tight":          "-0.03em",
      "heading":        "-0.02em",
      "snug":           "-0.01em",
      "normal":         "0",
      "ui":             "0.01em",
      "stat":           "0.04em",
      "label":          "0.14em",
      "overline-tight": "0.18em",
      "overline":       "0.22em"
    }
  },
  "spacing": {
    "$description": "8px grid spacing scale",
    "1":  4,
    "2":  8,
    "3":  12,
    "4":  16,
    "5":  20,
    "6":  24,
    "7":  28,
    "8":  32,
    "9":  36,
    "10": 40,
    "12": 48,
    "14": 56,
    "16": 64,
    "20": 80,
    "24": 96,
    "32": 128
  },
  "radius": {
    "none":     0,
    "sm":       4,
    "md":       8,
    "chip":     8,
    "card-img": 8,
    "input":    10,
    "card":     16,
    "panel":    16,
    "lg":       24,
    "pill":     999
  },
  "shadow": {
    "xs":    "0 1px 3px rgba(0,0,0,0.04)",
    "sm":    "0 2px 10px rgba(0,0,0,0.06)",
    "md":    "0 6px 24px rgba(0,0,0,0.08)",
    "lg":    "0 12px 48px rgba(0,0,0,0.10)",
    "panel": "0 2px 8px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.03)"
  },
  "motion": {
    "easing": {
      "default": "cubic-bezier(0.22, 1, 0.36, 1)",
      "spring":  "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "duration": {
      "fast":   140,
      "base":   220,
      "slow":   420,
      "reveal": 650
    }
  },
  "layout": {
    "maxWidth":    1340,
    "navHeight":   72,
    "padding":     { "min": 28, "max": 88 },
    "gutter":      { "min": 12, "max": 20 }
  },
  "components": {
    "$description": "Component class names and their CSS file locations",
    "navigation": {
      "classes": [".nav", ".nav.s", ".nav-inner", ".nav-logo", ".nav-links", ".nav-cta", ".nav-burger", ".nav-drawer", ".nav-right"],
      "file": "components.css"
    },
    "hero": {
      "classes": [".hero", ".hero-name", ".hero-name-line", ".hero-name-inner", ".hero-avail", ".hero-role-line", ".hero-role-text", ".hero-tagline", ".hero-descriptor", ".hero-sub", ".hero-stats", ".hero-stat", ".hero-cta", ".hero-scroll"],
      "file": "components.css"
    },
    "sectionHeading": {
      "classes": [".sh", ".sh-eyebrow", ".sh-row", ".sh-text", ".sh-period", ".sh-link", ".sh-title-group", ".sh-work-portrait"],
      "file": "components.css"
    },
    "card": {
      "classes": [".pcard", ".pcard-article", ".pcard-img", ".pcard-body", ".pcard-title", ".ph"],
      "file": "components.css"
    },
    "about": {
      "classes": [".about", ".about-bento", ".about-panel", ".about-eyebrow", ".about-intro", ".about-body", ".about-links", ".about-link", ".about-portrait-panel", ".about-skills-panel", ".skill"],
      "file": "components.css"
    },
    "contact": {
      "classes": [".contact", ".contact-bento", ".contact-left", ".contact-heading", ".contact-sub", ".contact-form-panel", ".contact-form", ".f-group", ".f-label", ".f-input", ".f-textarea", ".f-btn"],
      "file": "components.css"
    },
    "footer": {
      "classes": [".footer", ".footer-visual", ".footer-inner", ".footer-copy", ".footer-role", ".footer-li"],
      "file": "components.css"
    },
    "aurora": {
      "classes": [".orb", ".orb-1", ".orb-2", ".orb-3", ".orb-4", ".fv-orb", ".fv-orb-1", ".fv-orb-2", ".fv-orb-3"],
      "file": "components.css"
    },
    "themeToggle": {
      "classes": [".theme-toggle", ".theme-toggle--drawer", ".theme-icon--sun", ".theme-icon--moon"],
      "file": "components.css"
    },
    "utilities": {
      "classes": [".wrap", ".rv", ".skip-link", ".section-divider", ".bento"],
      "file": "components.css"
    }
  }
}
